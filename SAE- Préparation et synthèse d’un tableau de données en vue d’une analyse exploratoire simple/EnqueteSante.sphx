            <m id="RUSM59">
              <label>
                <fr>Pas envie</fr>
              </label>
              <shortlabel />
            </m>
            <m id="TVN8TV">
              <label>
                <fr>Difficultés financières</fr>
              </label>
              <shortlabel />
            </m>
            <m id="8F28M5">
              <label>
                <fr>Autre</fr>
              </label>
              <shortlabel />
            </m>
          </modalities>
        </variable>
