            <fr>La question n'est pertinente que si Alcool parmi "Oui".</fr>
          </instruction>
          <alert />
          <restrictions>
            <exp>
              <v>Alcool</v>
              <o>PARMI</o>
              <op>0;1</op>
            </exp>
          </restrictions>
          <modalities>
            <m id="7V89EK">
              <label>
                <fr>Aucune</fr>
              </label>
              <shortlabel />
            </m>
            <m id="35UQA4">
              <label>
                <fr>1 ou 2 fois</fr>
              </label>
              <shortlabel />
            </m>
            <m id="43URZS">
              <label>
                <fr>3 ou 4 fois</fr>
              </label>
              <shortlabel />
            </m>
            <m id="HHKLQ4">
              <label>
                <fr>Plus de 4 fois</fr>
              </label>
              <shortlabel />
            </m>
          </modalities>
        </variable>
