      <part id="1630587885" name="Vous_et_votre_sante" isexpanded="1">
        <label>
          <fr>Vous et votre santé</fr>
        </label>
        <shortlabel />
        <variable type="FU" id="806257044" name="Recurrent">
          <label>
            <fr>Souffrez-vous d'un problème de santé récurrent?</fr>
          </label>
