        <variable type="FU" id="1142968801" name="Alt">
          <label>
            <fr>Si vous êtes en licence pro, êtes-vous alternant?</fr>
          </label>
          <shortlabel />
          <instruction isauto="1">
            <fr>La question n'est pertinente que si Niveau parmi "Licence Pro".</fr>
          </instruction>
